---
const { sideBarActiveItemID } = Astro.props;
const base = import.meta.env.BASE_URL;
const activeClass = "bg-base-300";
---

<ul class="menu grow shrink menu-md overflow-y-auto">
  <li>
    <a class="py-3 text-base" id="home" href={base}>
      Home
    </a>
  </li>

  <li>
    <a class="py-3 text-base" id="projects" href={`${base}projects/`}>
      Projects
    </a>
  </li>

  <li>
    <a class="py-3 text-base" id="blog" href={`${base}blog/`}>
      Blog
    </a>
  </li>

  <li>
    <a class="py-3 text-base" id="cv" href={`${base}cv/`}>
      CV
    </a>
  </li>

  <li>
    <a
      class="py-3 text-base"
      href="mailto:contact.easonkuo980723@gmail.com"
      target="_blank"
      rel="noopener noreferrer"
    >
      Contact
    </a>
  </li>
</ul>

<script define:vars={{ sideBarActiveItemID, activeClass }}>
  const activeItemElem = document.getElementById(sideBarActiveItemID);

  if (activeItemElem) {
    activeItemElem.classList.add(activeClass);
  }
</script>